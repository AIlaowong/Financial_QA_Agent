# ── LLM 配置 ──
# 选择 LLM 提供商: openai | deepseek
LLM_PROVIDER=openai
# OpenAI 兼容 API Key (DeepSeek 也走 OpenAI 兼容接口)
OPENAI_API_KEY=sk-xxxx
# API 地址
OPENAI_BASE_URL=https://api.zhizengzeng.com/v1
LLM_MODEL=deepseek-v4-flash
# 红队 Agent 专用模型 (留空则使用 LLM_MODEL)
RED_TEAM_LLM_MODEL=deepseek-v4-pro

# ── 检索模型 (3路召回 + RRF + Reranker) ──
DENSE_EMBEDDING_MODEL=qwen3-embedding-8b
SPARSE_EMBEDDING_MODEL=text-embedding-3-small
RERANKER_MODEL=qwen3-rerank
DASHSCOPE_API_KEY=
RECALL_PER_PATH=10
RRF_TOP_K=10
RRF_K=60
RERANK_TOP_K=5
EMBEDDING_MODEL=text-embedding-3-small

# ── MinerU 精准解析 API ──
# 从 https://mineru.net 获取 Token
MINERU_TOKEN=
MINERU_BASE_URL=https://mineru.net/api/v4

# ── PaddleOCR-VL API ──
# 从百度智能云控制台获取: https://console.bce.baidu.com
PADDLEOCR_API_KEY=
PADDLEOCR_SECRET_KEY=

# ── PDF 解析策略 ──
# pymupdf  - 本地解析，速度最快
# mineru   - MinerU VLM 精准解析 (需 MINERU_TOKEN)
# paddleocr- PaddleOCR-VL API 解析 (需 PADDLEOCR_API_KEY)
# fallback - 降级链: MinerU → PaddleOCR → PyMuPDF
PARSER_STRATEGY=fallback
# PDF 文件路径
PDF_PATH=


# ── Agent 循环参数 ──
# 精修最大次数 (质量评分 < 阈值时触发)
MAX_REFINE_LOOPS=2
# 质量评分阈值 (1-10，达到此分不再精修)
QUALITY_THRESHOLD=8

# ── 检索参数 ──
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_K=5

# ── 日志 ──
LOG_LEVEL=INFO
